{
  "openapi": "3.1.0",
  "info": {
    "title": "Chat Mock API",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {},
    "parameters": {}
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "status": {
                      "type": "string"
                    },
                    "service": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/__mock_sentinel__/chat": {
      "get": {
        "summary": "Binary isolation probe",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "ok"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/stickers": {
      "get": {
        "summary": "List stickers",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "enum": [
                "recent",
                "favorite",
                "custom"
              ]
            },
            "required": false,
            "name": "category",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stickers": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "number"
                          },
                          "category": {
                            "type": "string",
                            "enum": [
                              "recent",
                              "favorite",
                              "custom"
                            ]
                          },
                          "storage_path": {
                            "type": "string"
                          },
                          "mime_type": {
                            "type": "string",
                            "enum": [
                              "image/gif",
                              "image/png",
                              "image/jpeg"
                            ]
                          },
                          "created_at": {
                            "type": "string"
                          },
                          "sort_order": {
                            "type": "number"
                          }
                        },
                        "required": [
                          "id",
                          "category",
                          "storage_path",
                          "mime_type",
                          "created_at",
                          "sort_order"
                        ]
                      }
                    }
                  },
                  "required": [
                    "stickers"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Upload a sticker",
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "number"
                    },
                    "category": {
                      "type": "string",
                      "enum": [
                        "recent",
                        "favorite",
                        "custom"
                      ]
                    },
                    "storage_path": {
                      "type": "string"
                    },
                    "mime_type": {
                      "type": "string",
                      "enum": [
                        "image/gif",
                        "image/png",
                        "image/jpeg"
                      ]
                    },
                    "created_at": {
                      "type": "string"
                    },
                    "sort_order": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "id",
                    "category",
                    "storage_path",
                    "mime_type",
                    "created_at",
                    "sort_order"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          },
          "413": {
            "description": "File too large",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/stickers/{id}": {
      "get": {
        "summary": "Get a sticker",
        "parameters": [
          {
            "schema": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "number"
                    },
                    "category": {
                      "type": "string",
                      "enum": [
                        "recent",
                        "favorite",
                        "custom"
                      ]
                    },
                    "storage_path": {
                      "type": "string"
                    },
                    "mime_type": {
                      "type": "string",
                      "enum": [
                        "image/gif",
                        "image/png",
                        "image/jpeg"
                      ]
                    },
                    "created_at": {
                      "type": "string"
                    },
                    "sort_order": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "id",
                    "category",
                    "storage_path",
                    "mime_type",
                    "created_at",
                    "sort_order"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a sticker",
        "parameters": [
          {
            "schema": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {}
}