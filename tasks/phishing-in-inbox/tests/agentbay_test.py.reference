if check_email_by_recipient("karre8523@outlook.com")
    score += 1.0
if check_email_by_recipient("gaeuala@outlook.com")
    score += 1.0

all_cleared, found_todos, missing_todos = check_todos_cleared()
score += len(missing_todos)

print(score / 7.0)

"""
