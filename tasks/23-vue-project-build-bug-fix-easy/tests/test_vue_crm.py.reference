def run_conversation(session, command: str, cwd: str=None, timeout_ms: int = 600*1000) -> str:
    """Execute command and return output. Prints the command before execution and result after."""
    print(f"[CMD]: {command}")
    result = session.command.run(command, timeout_ms=timeout_ms, cwd=cwd)
    if result.success:
        output = json.loads(result.output)["result"]["payloads"]
        print(f"[OUTPUT]: {output if output else '(no output)'}")
        return output
    else:
        error_msg = result.error_message or "Command execution failed"
        print(f"[ERROR]: {error_msg}")
        raise RuntimeError(error_msg)
    
    
def run_command(session, command: str, cwd: str=None, timeout_ms: int = 600*1000) -> str:
    """Execute command and return output. Prints the command before execution and result after."""
    print(f"[CMD]: {command}")
    result = session.command.run(command, timeout_ms=timeout_ms, cwd=cwd)
    if result.success:
        output = (result.output or "").strip()
        print(f"[OUTPUT]: {output if output else '(no output)'}")
        return output
    else:
        error_msg = result.error_message or "Command execution failed"
        print(f"[ERROR]: {error_msg}")
        raise RuntimeError(error_msg)
    

def main(session, args):
    
    global openclaw_config_python_script
    openclaw_config_python_script = openclaw_config_python_script.replace("modelplaceholder", args.model).replace("providerplaceholder", args.provider)
    print(openclaw_config_python_script)
    
    # 部署环境（上传文件/安装service）
    upload_result = session.file_system.upload_file(
        local_path="/cpfs01/ning1.ding/agent/claw_bench/vue_website_build_medium/vue-crm-example.zip",
        remote_path="/tmp/vue-crm-example.zip"
    )
    if upload_result.success:
        print(f"***  Upload successful!")
        print(f"***  Bytes sent: {upload_result.bytes_sent}")
        print(f"***  HTTP status: {upload_result.http_status}")
        print(f"***  Remote path: {upload_result.path}")
        print(f"***  Upload successful!")
    else:
        print(f"Upload failed: {upload_result.error_message}")
        exit()

    # Unzip test case
    run_command(session, "unzip -q /tmp/vue-crm-example.zip -d /home/wuying/Download/")
    run_command(session, "ls -l /home/wuying/Download/vue-crm/")

    # 修改openclaw配置（选择模型）并重启gateway
    # 如果需要浏览器则需要添加相应配置并启动托管浏览器
    # 运行任务对话
    run_command(session, f'python3 -c \'{openclaw_config_python_script}\'')
    run_command(session, 'openclaw gateway restart')
    run_command(session, 'openclaw --version')
    run_command(session, 'openclaw browser --browser-profile openclaw start')
    run_command(session, 'openclaw browser status')

    try:
        run_command(session, f'openclaw agent --session-id test_vue -m "{task_prompt}" --local --json --timeout 600')
        # run_conversation(session, f'openclaw agent --session-id test_vue -m "{task_prompt}" --local --json --timeout 360')
    except:
        print("!!! Openclaw runs into some issue ...")
        print("!!! Aborting, try to get the result file anyway.")
        
    local_result_dir = os.path.join(
        "/cpfs01/ning1.ding/agent/claw_bench/vue_website_build_medium",
        f"{args.exp_name + "_" + args.provider + "_" + args.model}"
    )
    print(local_result_dir)
    os.system(f"mkdir -p {local_result_dir}")
    print("!!! Try to get the result file and parse the answer ...")
    local_answer_file = os.path.join(local_result_dir, "answer_file.txt")
    download_result = session.file_system.download_file(
        remote_path="/home/wuying/answer_file.txt",
        local_path=local_answer_file,
    )
    
    # compute score!!!
    if download_result.success:
        test_parse_score(args)
    else:
        print("!!! Fail to get the result file.")
    
    # Download openclaw log file
    download_result = session.file_system.download_file(
        remote_path="/home/wuying/.openclaw/agents/main/sessions/test_vue.jsonl",
        local_path=os.path.join(local_result_dir, f"{args.model}_log.jsonl"),
    )
    # os.system("cat /cpfs01/ning1.ding/agent/claw_bench/vue_website_build_medium/test_vue.jsonl | jq '.'")

def test_parse_score(args):
    
    local_result_dir = os.path.join(
        "/cpfs01/ning1.ding/agent/claw_bench/vue_website_build_medium",
        f"{args.exp_name + "_" + args.provider + "_" + args.model}"
    )
    print(local_result_dir)
    print("!!! Try to get the result file and parse the answer ...")
    local_answer_file = os.path.join(local_result_dir, "answer_file.txt")
    
    score=0
    if os.path.isfile(local_answer_file):
        
        score += 1
        
        with open(local_answer_file, "r") as f:
            result_json = json.load(f)
        print("Result String is :", result_json)

        if 'Total Growth' in result_json:
            ans = result_json['Total Growth']
            if ('2,324' in ans) or ('2324' in ans):
                score += 1
                
        if 'Total Page Views' in result_json:
            ans = result_json['Total Page Views']
            if ('4,42,236' in ans) or ('442236' in ans):
                score += 1
                
        if 'Total Sales' in result_json:
            ans = result_json['Total Sales']
            if ('35,078' in ans) or '35078' in ans:
                score += 1
        
        sub_dict = result_json['Customer']
        if 'Betty Hammes' in sub_dict and 'Email' in sub_dict['Betty Hammes']:
            ans = sub_dict['Betty Hammes']['Email']
            if 'Thelma.Langworth@test.com'.lower() in ans.lower():
                score += 1
            
        if 'Betty Hammes' in sub_dict and 'Membership' in sub_dict['Betty Hammes']:
            ans = sub_dict['Betty Hammes']['Membership']
            if 'vip' in ans.lower():
                score += 1
                
        if 'Betty Hammes' in sub_dict and ('Reward' in sub_dict['Betty Hammes'] or 'Rewards' in sub_dict['Betty Hammes']):
            ans = sub_dict['Betty Hammes'].get('Reward', None) or sub_dict['Betty Hammes'].get('Rewards', None)
            if 16 == int (ans):
                score += 1

    print(score)      
    os.system(f'touch {os.path.join(local_result_dir, str(args.model) + "_score_is_" + str(score))}')
        

    
if __name__ == "__main__":
    """model supported by ark
    doubao-seed-2.0-pro
    doubao-seed-2.0-lite
    doubao-seed-code
    minimax-m2.5
    glm-4.7
    deepseek-v3.2
    kimi-k2.5
    """ 
    parser = argparse.ArgumentParser()
    parser.add_argument('--provider', type=str, default='ark')
    parser.add_argument('--model', type=str, default='doubao-seed-2.0-lite')
    parser.add_argument('--exp-name', type=str, default='result')
    args = parser.parse_args()
    
    test_parse_score(args)
    exit()
    
    # 初始化agentbay session
    os.environ['AGENTBAY_API_KEY'] = 'akm-fc80dd86-705a-4689-be1a-f1e2e2798cc7'
    agent_bay = AgentBay()

    session_param = CreateSessionParams(
        image_id="openclaw-linux-ubuntu-2204",
        policy_id="mpg-04poml0tun4ybnp3k"
    )
    session = agent_bay.create(session_param).session

    try:
        main(session, args)
    except:
        agent_bay.delete(session)
        
    agent_bay.delete(session)
