from agentbay import AgentBay, CreateSessionParams
import os
import json
import subprocess


def run_conversation(session, command: str, cwd: str=None, timeout_ms: int = 500000) -> str:
    """Execute command and return output. Prints the command before execution and result after."""
    print(f"[CMD]: {command}")
    result = session.command.run(command, timeout_ms=timeout_ms, cwd=cwd)
    if result.success:
        output = json.loads(result.output)["result"]["payloads"]
        print(f"[OUTPUT]: {output if output else '(no output)'}")
        return output
    else:
        error_msg = result.error_message or "Command execution failed"
        print(f"[ERROR]: {error_msg}")
        raise RuntimeError(error_msg)


def run_command(session, command: str, cwd: str=None, timeout_ms: int = 500000) -> str:
    """Execute command and return output. Prints the command before execution and result after."""
    print(f"[CMD]: {command}")
    result = session.command.run(command, timeout_ms=timeout_ms, cwd=cwd)
    if result.success:
        output = (result.output or "").strip()
        print(f"[OUTPUT]: {output if output else '(no output)'}")
        return output
    else:
        error_msg = result.error_message or "Command execution failed"
        print(f"[ERROR]: {error_msg}")
        raise RuntimeError(error_msg)


# 1. Initialize agentbay session
os.environ['AGENTBAY_API_KEY'] = 'akm-fc80dd86-705a-4689-be1a-f1e2e2798cc7'
agent_bay = AgentBay()
session = agent_bay.create(CreateSessionParams(image_id="openclaw-linux-ubuntu-2204")).session


# 2. Deploy environment (upload files/install services)
# Upload environment folder (contains task.md and test-runner/)
subprocess.run(["tar", "-zcvf", "/tmp/environment.tar.gz", "environment"], cwd="/tmp")
upload_result = session.file_system.upload_file(
    local_path="/tmp/environment.tar.gz",
    remote_path="/tmp/environment.tar.gz"
)
if upload_result.success:
    print(f"Upload environment successful!")
    print(f"   Bytes sent: {upload_result.bytes_sent}")
    print(f"   HTTP status: {upload_result.http_status}")
    print(f"   Remote path: {upload_result.path}")
else:
    print(f"Upload environment failed: {upload_result.error_message}")

run_command(session, "tar -xzvf /tmp/environment.tar.gz -C /tmp/")

# Upload tests folder
subprocess.run(["tar", "-zcvf", "/tmp/tests.tar.gz", "tests"], cwd="/tmp")
upload_result = session.file_system.upload_file(
    local_path="/tmp/tests.tar.gz",
    remote_path="/tmp/tests.tar.gz"
)
if upload_result.success:
    print(f"Upload tests successful!")
else:
    print(f"Upload tests failed: {upload_result.error_message}")

run_command(session, "tar -xzvf /tmp/tests.tar.gz -C /tmp/")

# Upload task.md separately
upload_result = session.file_system.upload_file(
    local_path="/cpfs01/liziheng/codes/blog/task.md",
    remote_path="/tmp/task.md"
)
if upload_result.success:
    print(f"Upload task.md successful!")
else:
    print(f"Upload task.md failed: {upload_result.error_message}")

run_command(session, "node --version")
run_command(session, "npm --version")

# 3. Run OpenClaw conversation to build stellar-db from task.md
with open("../task.md", "r", encoding="utf-8") as file:
    task_inst = file.read()

# Configure OpenClaw to use appropriate model
python_script = """
import json
config_path = "/home/wuying/.openclaw/openclaw.json"
with open(config_path, "r") as f:
    config = json.load(f)

config["models"]["providers"]["ark"] = {
    "baseUrl": "https://ark.cn-beijing.volces.com/api/coding/v3",
    "apiKey": "50106bfe-c1be-49a2-ba5a-40cda9f9e38b",
    "api": "openai-completions",
    "models": [{"id": "Kimi-K2.5", "name": "Kimi-K2.5"}]
}

config["agents"]["defaults"]["model"]["primary"] = "ark/Kimi-K2.5"

with open(config_path, "w") as f:
    json.dump(config, f, indent=2)
print("done")
"""
run_command(session, f'python3 -c \'{python_script}\'')
run_command(session, 'openclaw gateway restart')
run_command(session, 'openclaw --version')

# Run OpenClaw to build stellar-db project
run_conversation(
    session,
    f"openclaw agent --session-id test-stellar-db -m \"Build a blog system according to /tmp/task.md. Create the stellar-db directory at /tmp/environment/stellar-db and implement all required features.\" --json --timeout 600",
    cwd="/tmp"
)


# 4. Install dependencies after OpenClaw builds the project
run_command(session, "npm install", cwd="/tmp/environment/stellar-db")
run_command(session, "npm install", cwd="/tmp/environment/test-runner")


# 5. Run tests to validate the built project
test_output = run_command(
    session,
    "node tests/scripts/test-summary.mjs",
    cwd="/tmp",
    timeout_ms=600000
)


# 6. Parse results and calculate score
import re

test_cases_match = re.search(r'Test Cases Passed:\s+(\d+)/(\d+)', test_output)
milestones_match = re.search(r'Milestones Completed:\s+(\d+)/(\d+)', test_output)

test_cases_passed = 0
test_cases_total = 21
milestones_completed = 0
milestones_total = 5

if test_cases_match:
    test_cases_passed = int(test_cases_match.group(1))
    test_cases_total = int(test_cases_match.group(2))

if milestones_match:
    milestones_completed = int(milestones_match.group(1))
    milestones_total = int(milestones_match.group(2))

# Calculate score: 0.5 for test cases, 0.5 for milestones
test_score = (test_cases_passed / test_cases_total) * 0.5
milestone_score = (milestones_completed / milestones_total) * 0.5
final_score = test_score + milestone_score

print(f"\nTest Cases: {test_cases_passed}/{test_cases_total}")
print(f"Milestones: {milestones_completed}/{milestones_total}")
print(f"Final Score: {final_score:.2f}/1.0\n")

# Save result
with open("../result.jsonl", "a") as file:
    line = {
        "task": "stellar_db_blog_system",
        "test_cases_passed": test_cases_passed,
        "test_cases_total": test_cases_total,
        "milestones_completed": milestones_completed,
        "milestones_total": milestones_total,
        "score": final_score,
    }
    file.write(json.dumps(line) + "\n")

agent_bay.delete(session)
