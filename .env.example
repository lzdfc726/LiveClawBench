# ==============================================================
# LiveClawBench — Inference Endpoint Configuration
# ==============================================================
# Rename to .env and fill in your credentials.
#
# REQUIREMENT: Your model endpoint MUST support the OpenAI
# Chat Completions API (/v1/chat/completions).
#
# OPTIONAL: Responses API (/v1/responses) is supported by Harbor
# when use_responses_api=True — not required for standard evaluation.
#
# Model format passed to harbor: provider/model-id
# Examples:
#   volcengine-plan/kimi-k2.5
#   openai/gpt-4o
#   anthropic/claude-opus-4-6
#   custom/deepseek-chat        (any OpenAI-compatible endpoint)
# ==============================================================

# --- Option A: OpenAI or any OpenAI-compatible endpoint ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://your-custom-endpoint.com/v1   # omit for api.openai.com

# --- Option B: Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Option C: VolcEngine (火山引擎) ---
# Model format: volcengine/<model-id> or volcengine-plan/<model-id>
# VOLCANO_ENGINE_API_KEY=...

# --- Option D: Google Gemini ---
# GEMINI_API_KEY=...

# --- OpenClaw Gateway Token ---
# Required only if your task uses browser tools through the OpenClaw gateway.
# Most tasks do not need this.
# OPENCLAW_GATEWAY_TOKEN=...

# --- Option E: Custom OpenAI-compatible endpoint ---
# Use with: harbor run -m custom/<model-id> --ae CUSTOM_BASE_URL="..." --ae CUSTOM_API_KEY="..."
# CUSTOM_BASE_URL=https://api.deepseek.com/v1
# CUSTOM_API_KEY=...
